# Common local-development overrides. Other settings use config defaults.
SERVICE_NAME=go-backend-architecture
APP_ENV=local

# HTTP
HTTP_ADDRESS=:8080
HTTP_CORS_ALLOW_ORIGINS=http://localhost:3000
# Comma-separated CIDRs for reverse proxies whose X-Forwarded-For header is trusted.
HTTP_TRUSTED_PROXY_CIDRS=

# Data services
DB_URL=postgres://postgres:postgres@localhost:5432/go-backend-architecture?sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Observability and logging
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=debug
OTEL_LOG_LEVEL=debug

# Session security: set true outside local development.
SESSION_COOKIE_SECURE=false

# Optional email delivery. Unset uses the log-only OTP sender.
RESEND_API_KEY=
RESEND_FROM=

# Optional Google OAuth login. Unset disables the provider.
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
