SERVICE_NAME=go-backend-architecture
APP_ENV=local

HTTP_ADDRESS=:8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s

DB_URL=postgres://postgres:postgres@localhost:5432/go-backend-architecture?sslmode=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME=30m
DB_MAX_CONN_IDLE_TIME=5m
DB_HEALTH_CHECK_PERIOD=1m
DB_CONNECT_TIMEOUT=5s

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_DIAL_TIMEOUT=3s
REDIS_READ_TIMEOUT=2s
REDIS_WRITE_TIMEOUT=2s
REDIS_CACHE_TTL=2m

OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_INSECURE=true
OTEL_TRACES_SAMPLER_RATIO=1.0
# Optional: override per-signal endpoint when collector exposes custom paths.
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=

LOG_LEVEL=debug
OTEL_LOG_LEVEL=debug
LOG_DEVELOPMENT=true

SESSION_TTL=24h
SESSION_COOKIE_NAME=session
SESSION_COOKIE_SECURE=false

OTP_TTL=5m
OTP_CODE_LENGTH=6

# Optional: Resend for OTP email. If RESEND_API_KEY is unset, OTP uses stub (log only).
RESEND_API_KEY=
RESEND_FROM=

# Optional: Google OAuth login (Sign in with Google). If OAUTH_GOOGLE_CLIENT_ID is unset, Google login is disabled.
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URL=http://localhost:8080/auth/oauth/google/callback

SHUTDOWN_GRACE_PERIOD=10s
